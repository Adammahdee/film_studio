CREATE DATABASE film_studio;
USE film_studio;

CREATE TABLE users (
    user_id INT PRIMARY KEY AUTO_INCREMENT,
    full_name VARCHAR(100) NOT NULL,
    password VARCHAR(255) NOT NULL,
    role VARCHAR(20) NOT NULL
);

CREATE TABLE items (
    item_id INT PRIMARY KEY AUTO_INCREMENT,
    item_name VARCHAR(150) NOT NULL UNIQUE,
    quantity INT DEFAULT 0 CHECK (quantity >= 0)
);

CREATE TABLE purchase_requests (
    request_id INT PRIMARY KEY AUTO_INCREMENT,
    item_name VARCHAR(150) NOT NULL,
    quantity INT NOT NULL CHECK (quantity > 0),
    requested_by INT NOT NULL,
    status VARCHAR(20) DEFAULT 'pending',

    FOREIGN KEY (requested_by) REFERENCES users(user_id)
);

CREATE TABLE approvals (
    approval_id INT PRIMARY KEY AUTO_INCREMENT,
    request_id INT NOT NULL,
    approved_by INT NOT NULL,
    decision VARCHAR(20) NOT NULL,

    FOREIGN KEY (request_id) REFERENCES purchase_requests(request_id),
    FOREIGN KEY (approved_by) REFERENCES users(user_id)
);

CREATE TABLE inventory (
    item_id INT AUTO_INCREMENT PRIMARY KEY,
    item_name VARCHAR(255) NOT NULL,
    quantity INT NOT NULL,
    status ENUM('AVAILABLE','OUT_OF_STOCK') DEFAULT 'AVAILABLE',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

ALTER TABLE purchase_requests
ADD CONSTRAINT chk_status
CHECK (status IN ('pending','approved','rejected'));

ALTER TABLE approvals
ADD CONSTRAINT chk_decision
CHECK (decision IN ('approved','rejected'));film_studio